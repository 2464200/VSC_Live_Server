# Default: normalize text files in the repository
* text=auto

# Keep web/data sources in LF across platforms
*.csv text eol=lf
*.js text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Windows shell scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets
*.xlsm binary
*.xlsx binary
*.xls binary
*.zip binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary