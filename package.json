{
  "name": "scriptpdf-server",
  "version": "2.0.0",
  "description": "Server stabile per gestione PDF con auto-start/stop",
  "main": "server-manager.js",
  "scripts": {
    "start": "node server-manager.js",
    "start:pdf": "node pdf-server-simple.js",
    "start:web": "node simple-server.js",
    "start:all": "concurrently \"npm run start\" \"npm run start:web\"",
    "dev": "nodemon server-manager.js"
  },
  "keywords": [
    "pdf",
    "chrome",
    "kiosk",
    "excel",
    "choreography"
  ],
  "author": "Admin",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
